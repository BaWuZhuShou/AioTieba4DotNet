<Project>
    <PropertyGroup>
        <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
        <TargetFramework Condition="'$(TargetFramework)' == '' And '$(TargetFrameworks)' == ''">net10.0</TargetFramework>
        <LangVersion>14.0</LangVersion>
        <Deterministic>true</Deterministic>
        <DeterministicSourcePaths>true</DeterministicSourcePaths>
        <DebugType>portable</DebugType>
        <PublishRepositoryUrl>true</PublishRepositoryUrl>
        <EmbedUntrackedSources>true</EmbedUntrackedSources>
        <EnableNETAnalyzers>true</EnableNETAnalyzers>
        <AnalysisLevel>latest-recommended</AnalysisLevel>
        <AnalysisMode>Recommended</AnalysisMode>
        <RunAnalyzersDuringBuild>false</RunAnalyzersDuringBuild>
        <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    </PropertyGroup>

    <PropertyGroup>
        <IsOnlineMergedScenarioTestProject Condition="'$(MSBuildProjectName)' == 'AioTieba4DotNet.Tests.Online'">true</IsOnlineMergedScenarioTestProject>
        <IsOnlineGovernanceTestProject Condition="'$(MSBuildProjectName)' == 'AioTieba4DotNet.Tests.Governance'">true</IsOnlineGovernanceTestProject>
        <IsOnlineScenarioProject Condition="'$(IsOnlineMergedScenarioTestProject)' == 'true'">true</IsOnlineScenarioProject>
        <IsOnlineContractProject Condition="'$(IsOnlineGovernanceTestProject)' == 'true'">true</IsOnlineContractProject>
        <IsOnlineTestProject Condition="'$(IsOnlineScenarioProject)' == 'true' Or '$(IsOnlineContractProject)' == 'true'">true</IsOnlineTestProject>
    </PropertyGroup>

    <PropertyGroup Condition="'$(IsOnlineTestProject)' == 'true'">
        <IsTestProject>true</IsTestProject>
        <IsPackable>false</IsPackable>
        <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    </PropertyGroup>

    <PropertyGroup Condition="'$(TF_BUILD)' == 'true' Or '$(GITHUB_ACTIONS)' == 'true' Or '$(APPVEYOR)' == 'true' Or '$(CI)' == 'true'">
        <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    </PropertyGroup>
</Project>
